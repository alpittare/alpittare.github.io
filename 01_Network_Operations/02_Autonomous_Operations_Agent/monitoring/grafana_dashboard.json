{
  "dashboard": {
    "title": "Autonomous Operations Agent",
    "description": "Monitoring dashboard for Autonomous Operations Agent use case",
    "timezone": "browser",
    "tags": [
      "telecom",
      "ai-ml",
      "autonomous-ops"
    ],
    "panels": [
      {
        "id": 1,
        "title": "Service Uptime",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job='autonomous-ops'}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Request Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{job='autonomous-ops'}[5m])"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 6,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{job='autonomous-ops',status=~'5..'}[5m])"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 4,
        "title": "Response Latency P95",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job='autonomous-ops'}[5m]))"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 18,
          "y": 0
        }
      },
      {
        "id": 5,
        "title": "CPU Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total{job='autonomous-ops'}[5m]) * 100"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 6,
        "title": "Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "process_resident_memory_bytes{job='autonomous-ops'} / 1e9"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 6,
          "y": 8
        }
      },
      {
        "id": 7,
        "title": "Disk Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "node_filesystem_used_bytes{fstype!='tmpfs'} / node_filesystem_size_bytes"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 12,
          "y": 8
        }
      },
      {
        "id": 8,
        "title": "Network I/O",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(network_receive_bytes_total{job='autonomous-ops'}[5m])"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 18,
          "y": 8
        }
      },
      {
        "id": 9,
        "title": "Inference Latency P99",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.99, rate(prediction_latency_seconds_bucket{job='autonomous-ops'}[5m]))"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 0,
          "y": 16
        }
      },
      {
        "id": 10,
        "title": "Model Accuracy",
        "type": "graph",
        "targets": [
          {
            "expr": "model_accuracy{job='autonomous-ops'}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 6,
          "y": 16
        }
      },
      {
        "id": 11,
        "title": "Model Drift Score",
        "type": "graph",
        "targets": [
          {
            "expr": "model_drift_score{job='autonomous-ops'}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 12,
          "y": 16
        }
      },
      {
        "id": 12,
        "title": "Anomaly Rate Timeline",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(anomaly_detections_total{job='autonomous-ops'}[5m])"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 18,
          "y": 16
        }
      },
      {
        "id": 13,
        "title": "Isolation Forest Scores",
        "type": "heatmap",
        "targets": [
          {
            "expr": "histogram_quantile([0.25, 0.5, 0.75, 0.99], rate(isolation_forest_score_bucket{job='autonomous-ops'}[5m]))"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 24
        }
      },
      {
        "id": 14,
        "title": "Autoencoder Reconstruction Error",
        "type": "graph",
        "targets": [
          {
            "expr": "autoencoder_reconstruction_error{job='autonomous-ops'}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 24
        }
      },
      {
        "id": 15,
        "title": "Kafka Consumer Lag",
        "type": "graph",
        "targets": [
          {
            "expr": "kafka_consumer_lag_sum{job='autonomous-ops'}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 32
        }
      }
    ],
    "schemaVersion": 27,
    "version": 0
  }
}