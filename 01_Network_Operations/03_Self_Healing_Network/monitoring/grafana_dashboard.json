{
  "dashboard": {
    "title": "Self-Healing Network",
    "description": "Monitoring dashboard for Self-Healing Network use case",
    "timezone": "browser",
    "tags": [
      "telecom",
      "ai-ml",
      "self-healing"
    ],
    "panels": [
      {
        "id": 1,
        "title": "Service Uptime",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job='self-healing'}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Request Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{job='self-healing'}[5m])"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 6,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{job='self-healing',status=~'5..'}[5m])"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 4,
        "title": "Response Latency P95",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job='self-healing'}[5m]))"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 18,
          "y": 0
        }
      },
      {
        "id": 5,
        "title": "CPU Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total{job='self-healing'}[5m]) * 100"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 6,
        "title": "Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "process_resident_memory_bytes{job='self-healing'} / 1e9"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 6,
          "y": 8
        }
      },
      {
        "id": 7,
        "title": "Disk Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "node_filesystem_used_bytes{fstype!='tmpfs'} / node_filesystem_size_bytes"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 12,
          "y": 8
        }
      },
      {
        "id": 8,
        "title": "Network I/O",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(network_receive_bytes_total{job='self-healing'}[5m])"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 18,
          "y": 8
        }
      },
      {
        "id": 9,
        "title": "Inference Latency P99",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.99, rate(prediction_latency_seconds_bucket{job='self-healing'}[5m]))"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 0,
          "y": 16
        }
      },
      {
        "id": 10,
        "title": "Model Accuracy",
        "type": "graph",
        "targets": [
          {
            "expr": "model_accuracy{job='self-healing'}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 6,
          "y": 16
        }
      },
      {
        "id": 11,
        "title": "Model Drift Score",
        "type": "graph",
        "targets": [
          {
            "expr": "model_drift_score{job='self-healing'}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 12,
          "y": 16
        }
      },
      {
        "id": 12,
        "title": "Healing Loop Status",
        "type": "stat",
        "targets": [
          {
            "expr": "healing_loops_active{job='self-healing'}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 18,
          "y": 16
        }
      },
      {
        "id": 13,
        "title": "Fault Type Distribution",
        "type": "pie",
        "targets": [
          {
            "expr": "sum by (fault_type) (increase(faults_detected_total{job='self-healing'}[1h]))"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 24
        }
      },
      {
        "id": 14,
        "title": "Remediation Success Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(remediation_success_total{job='self-healing'}[5m]) / (rate(remediation_attempts_total{job='self-healing'}[5m]) + 0.0001)"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 24
        }
      },
      {
        "id": 15,
        "title": "Guardrail Status",
        "type": "stat",
        "targets": [
          {
            "expr": "guardrail_breaches_total{job='self-healing'}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 32
        }
      },
      {
        "id": 16,
        "title": "System Health Score",
        "type": "gauge",
        "targets": [
          {
            "expr": "health_score{job='self-healing'}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 32
        }
      }
    ],
    "schemaVersion": 27,
    "version": 0
  }
}