{
  "dashboard": {
    "title": "Incident Correlation RCA",
    "description": "Monitoring dashboard for Incident Correlation and Root Cause Analysis",
    "timezone": "browser",
    "tags": [
      "telecom",
      "ai-ml",
      "rca",
      "incident"
    ],
    "panels": [
      {
        "id": 1,
        "title": "Service Uptime",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job='incident-correlation'}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Request Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{job='incident-correlation'}[5m])"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 6,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{job='incident-correlation',status=~'5..'}[5m])"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 4,
        "title": "Response Latency P95",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job='incident-correlation'}[5m]))"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 18,
          "y": 0
        }
      },
      {
        "id": 5,
        "title": "CPU Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total{job='incident-correlation'}[5m]) * 100"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 6,
        "title": "Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "process_resident_memory_bytes{job='incident-correlation'} / 1e9"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 6,
          "y": 8
        }
      },
      {
        "id": 7,
        "title": "Disk Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "node_filesystem_used_bytes{fstype!='tmpfs'} / node_filesystem_size_bytes"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 12,
          "y": 8
        }
      },
      {
        "id": 8,
        "title": "Network I/O",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(network_receive_bytes_total{job='incident-correlation'}[5m])"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 18,
          "y": 8
        }
      },
      {
        "id": 9,
        "title": "Inference Latency P99",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.99, rate(prediction_latency_seconds_bucket{job='incident-correlation'}[5m]))"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 0,
          "y": 16
        }
      },
      {
        "id": 10,
        "title": "Model Accuracy",
        "type": "graph",
        "targets": [
          {
            "expr": "model_accuracy{job='incident-correlation'}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 6,
          "y": 16
        }
      },
      {
        "id": 11,
        "title": "Model Drift Score",
        "type": "graph",
        "targets": [
          {
            "expr": "model_drift_score{job='incident-correlation'}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 12,
          "y": 16
        }
      },
      {
        "id": 12,
        "title": "Alarm Rate (per minute)",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(alarms_received_total{job='incident-correlation'}[1m])"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 18,
          "y": 16
        }
      },
      {
        "id": 13,
        "title": "DBSCAN Cluster Count",
        "type": "stat",
        "targets": [
          {
            "expr": "dbscan_cluster_count{job='incident-correlation'}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 24
        }
      },
      {
        "id": 14,
        "title": "Correlation Confidence Distribution",
        "type": "heatmap",
        "targets": [
          {
            "expr": "histogram_quantile([0.25, 0.5, 0.75, 0.99], rate(correlation_confidence_bucket{job='incident-correlation'}[5m]))"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 24
        }
      },
      {
        "id": 15,
        "title": "RCA Analysis Depth",
        "type": "stat",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(rca_analysis_depth_bucket{job='incident-correlation'}[5m]))"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 32
        }
      },
      {
        "id": 16,
        "title": "RCA Timeout Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(rca_timeout_total{job='incident-correlation'}[5m])"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 32
        }
      }
    ],
    "schemaVersion": 27,
    "version": 0
  }
}