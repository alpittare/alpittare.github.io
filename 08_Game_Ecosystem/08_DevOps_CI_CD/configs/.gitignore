# ============================================================================
# Game Ecosystem - Comprehensive .gitignore
# ============================================================================
# This file prevents accidental commits of sensitive data, build artifacts,
# and platform-specific files
# ============================================================================

# ============================================================================
# Environment & Secrets
# ============================================================================
.env
.env.local
.env.*.local
.env.production
.env.staging
.env.development
.env.test
*.pem
*.p8
*.p12
*.cer
*.key
*.keystore
AuthKey_*.p8

# ============================================================================
# Dependencies
# ============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml
.yarn/
.pnp
.pnp.js

# ============================================================================
# Build Artifacts
# ============================================================================
dist/
build/
.next/
out/
coverage/
*.ipa
*.apk
*.aab
.expo/
.expo-shared/

# ============================================================================
# iOS-Specific
# ============================================================================
ios/Pods/
ios/Podfile.lock
ios/.DS_Store
ios/build/
ios/DerivedData/
ios/*.xcarchive
ios/*.ipa
ios/certificates/
ios/provisioning_profiles/
ios/signing/
build.keychain*

# Xcode
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.swiftpm/xcode/package.resolved
DerivedData/
.xcode.env.local
.xcode.env

# CocoaPods
Pods/
*.lock

# ============================================================================
# Android-Specific
# ============================================================================
android/.gradle
android/local.properties
android/gradle.properties
android/**/build/
android/captures/
android/.externalNativeBuild
android/.cxx/
android/app/release/
android/keystore/
*.jks
*.keystore

# ============================================================================
# IDE & Editor
# ============================================================================
.vscode/
.idea/
.sublime-project
.sublime-workspace
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# WebStorm
.WebStorm*
*.iml

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt][a-z]
*~

# ============================================================================
# OS-Specific
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
desktop.ini

# ============================================================================
# Logs
# ============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
lerna-debug.log*

# ============================================================================
# Testing
# ============================================================================
.nyc_output/
.coverage/
.jest-cache/
.mocha-cache/
*.lcov

# ============================================================================
# Temporary Files
# ============================================================================
*.tmp
*.temp
*.bak
*.backup
*.swp
*.swo
*~
.cache/
.temp/

# ============================================================================
# Certificates & Keys (Security-Critical)
# ============================================================================
*.crt
*.pem
*.p12
*.p8
*.key
*.keystore
*.jks
*.cer
certificates/
keys/
secrets/
private_keys/
signing/

# ============================================================================
# GitHub Actions & CI/CD
# ============================================================================
.github/workflows/secrets*
ci.log
deploy.log

# ============================================================================
# Expo & EAS
# ============================================================================
.expo/
.expo-shared/
eas.json.local
app.json.local

# ============================================================================
# Convex
# ============================================================================
.convex/
convex/node_modules/

# ============================================================================
# Vercel
# ============================================================================
.vercel/
*.vercel.json.local

# ============================================================================
# Local Configuration Files
# ============================================================================
local.config.js
local.env
.local/
.config.local.js

# ============================================================================
# System Files
# ============================================================================
.directory
.directory/
.AppleDouble
.LSOverride

# ============================================================================
# Documentation & Generated Files
# ============================================================================
docs/generated/
api-docs/generated/

# ============================================================================
# Database Files
# ============================================================================
*.db
*.sqlite
*.sqlite3
*.pdb

# ============================================================================
# Node-gyp
# ============================================================================
build/Release

# ============================================================================
# Miscellaneous
# ============================================================================
dist/
.next
out/
.nuxt
.cache/
.vuepress/dist/
.serverless/
.fusebox/
.dynamodb/
.tern-port
.vscode-test
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ============================================================================
# Platform-Specific Build Directories
# ============================================================================
.artifacts/
artifacts/
release/
releases/
staging/
