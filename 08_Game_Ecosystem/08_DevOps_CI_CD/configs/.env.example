# ============================================================================
# Game Ecosystem - Environment Variables Template
# ============================================================================
# Copy this file to .env and populate with actual values
# NEVER commit actual .env file to repository
# ============================================================================

# ============================================================================
# Convex Backend Configuration
# ============================================================================
# Obtain from: https://dashboard.convex.dev
# These are your backend API credentials

VITE_CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOY_KEY=your-deploy-key-here
# Used for: Database queries, leaderboard sync, session management

# ============================================================================
# Apple App Store & Signing Configuration
# ============================================================================
# Obtain from: Apple Developer Account > Account Settings

APPLE_TEAM_ID=XXXXXXXXXX
# Example: ABC123DEFG
# Used for: iOS code signing, provisioning, App Store Connect access

ASC_APP_ID=1234567890
# The App ID in App Store Connect
# Used for: Identifying your app in App Store Connect

# ============================================================================
# In-App Purchase & Payments (Superwall)
# ============================================================================
# Obtain from: https://dashboard.superwall.com

SUPERWALL_API_KEY=sk_live_your_api_key_here
# Live API key for production payments
# Used for: VIP subscription management, virtual currency sales

SUPERWALL_API_KEY_DEV=sk_test_your_dev_key_here
# Test/dev API key (optional, for staging)
# Used for: Testing payments without charging

# ============================================================================
# Error Tracking & Monitoring (Sentry - Optional)
# ============================================================================
# Obtain from: https://sentry.io

SENTRY_DSN=https://your-key@sentry.io/your-project-id
# Data Source Name for error reporting
# Used for: Crash reporting, performance monitoring
# Comment out to disable Sentry

SENTRY_ENVIRONMENT=production
# Options: production, staging, development

SENTRY_SAMPLE_RATE=1.0
# What percentage of transactions to sample (0.0-1.0)
# Use 0.1 for 10% sampling in production to reduce quota usage

# ============================================================================
# Deployment & CI/CD
# ============================================================================

# Vercel Deployment (Web)
VERCEL_TOKEN=your_vercel_token_here
VERCEL_PROJECT_ID=your_project_id
VERCEL_ORG_ID=your_org_id

# Expo & EAS (Mobile)
EXPO_TOKEN=your_expo_token_here
EXPO_ACCOUNT=your_expo_account_name

# GitHub (if using GitHub-hosted runners)
GITHUB_TOKEN=your_github_token

# ============================================================================
# Feature Flags
# ============================================================================

VITE_ENVIRONMENT=production
# Options: production, staging, development
# Used for: Feature toggling, API endpoints, debug logging

VITE_ENABLE_DEBUG=false
# Enable debug console logs (set to true in development)

VITE_ENABLE_ANALYTICS=true
# Enable event tracking to Convex

# ============================================================================
# Game Configuration
# ============================================================================

VITE_GAME_DIFFICULTY=normal
# Options: easy, normal, hard
# Used for: Default AI difficulty level

VITE_MAX_LEADERBOARD_SIZE=1000
# Number of top scores to display on leaderboard

VITE_SESSION_TIMEOUT=3600
# Session timeout in seconds (1 hour)

# ============================================================================
# Development Only (Do Not Use in Production)
# ============================================================================

# LOCAL_API_URL=http://localhost:3000
# Used when running Convex backend locally
# Comment out for production (uses VITE_CONVEX_URL instead)

# MOCK_DATA=false
# Enable mock data for testing without backend
# Only for development/testing

# ============================================================================
# Notes for CI/CD Integration
# ============================================================================
# 1. GitHub Secrets: Store all secrets in GitHub repository settings
#    - Settings > Secrets and variables > Actions
#    - Add each secret individually (CONVEX_DEPLOY_KEY, etc.)
#
# 2. Local Development:
#    - Copy this file to .env
#    - Fill in your local development values
#    - Never commit .env to git
#
# 3. Staging Environment:
#    - Create .env.staging with staging API keys
#    - Use in GitHub Actions for non-main branch deployments
#
# 4. Secret Rotation:
#    - Rotate CONVEX_DEPLOY_KEY quarterly
#    - Rotate API keys after team member departures
#    - Immediately rotate if exposed
#
# 5. Accessing Secrets in GitHub Actions:
#    - Reference as: ${{ secrets.SECRET_NAME }}
#    - Example: ${{ secrets.CONVEX_DEPLOY_KEY }}
#
# ============================================================================
