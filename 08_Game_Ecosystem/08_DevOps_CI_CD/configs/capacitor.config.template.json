{
  "appId": "com.alpittare.cricket.ai",
  "appName": "CrickBot AI",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "hostname": "localhost",
    "url": "https://capacitor.ionic.io/api/v1"
  },
  "ios": {
    "contentInset": "automatic",
    "scrollBounce": true,
    "limitsNavigationsToAppBoundDomains": true,
    "allowsInlineMediaPlayback": true,
    "allowsLinkPreview": false
  },
  "android": {
    "allowMixedContent": false,
    "webContentsDebuggingEnabled": false,
    "initialFocus": true
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "CapacitorGeolocation": {
      "enabled": false
    },
    "CapacitorCamera": {
      "enabled": false
    }
  },
  "cordova": {}
}
