{
  "name": "survival-arena",
  "version": "1.0.0",
  "description": "Survival Arena IO - AI-Powered Multiplayer Survival Game",
  "main": "index.html",
  "scripts": {
    "serve": "npx http-server . -p 8080 -o",
    "build:standalone": "echo 'Standalone build is pre-built in dist/'",
    "cap:init": "npx cap init \"Survival Arena\" com.survivalarenaio.app --web-dir dist",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/core": "^5.0.0",
    "@capacitor/ios": "^5.0.0",
    "@capacitor/preferences": "^5.0.0",
    "@capacitor/haptics": "^5.0.0",
    "@capacitor/status-bar": "^5.0.0",
    "@capacitor/splash-screen": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.0.0"
  },
  "author": "Alpit Tare",
  "license": "MIT"
}
