{
  "name": "football-pro-bot-ai",
  "version": "1.0.0",
  "description": "Football Pro Bot AI: AI Football Challenge - A production-grade penalty shootout game with TensorFlow.js powered goalkeeper AI",
  "main": "dist/index.html",
  "scripts": {
    "start": "npx serve dist",
    "cap:init": "npx cap init 'Football Pro Bot AI' com.footballprobotai.app --web-dir dist",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "cordova-plugin-purchase": "^13.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  },
  "author": "Alpit Tare",
  "license": "MIT"
}
