{
  "appId": "com.footballprobotai.app",
  "appName": "Football Pro Bot AI",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0a1628",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a1628"
    },
    "Haptics": {}
  },
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#0a1628",
    "preferredContentMode": "mobile",
    "scheme": "FootballProBotAI"
  },
  "android": {
    "backgroundColor": "#0a1628",
    "allowMixedContent": true
  },
  "server": {
    "iosScheme": "capacitor",
    "androidScheme": "https"
  }
}
